# Maxions Environment Variables

# GitHub App credentials — used for git clone, push, and opening PRs
GITHUB_APP_ID=123456
# Paste the PEM private key on a single line with literal \n between lines
GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
GITHUB_APP_INSTALLATION_ID=78901234

# GitHub PAT with Copilot access — pi checks COPILOT_GITHUB_TOKEN before GITHUB_TOKEN
COPILOT_GITHUB_TOKEN=ghp_your_copilot_pat_here

# SQLite database file path (used by libSQL)
DATABASE_URL=file:./maxions.db

# API server port
API_PORT=3000

# Web dashboard port (Next.js)
WEB_PORT=3002

# Target GitHub repository for maxions
TARGET_REPO=Illusion47586/isol8
