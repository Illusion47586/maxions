{
  "name": "maxions",
  "private": true,
  "packageManager": "bun@1.2.20",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "ultracite fix",
    "lint:check": "ultracite check",
    "type-check": "turbo run type-check",
    "db:migrate": "bun run --cwd packages/db migrate",
    "clean": "turbo run clean"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.5",
    "@types/node": "^22.10.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "ultracite": "^7.2.4"
  },
  "trustedDependencies": [
    "@libsql/client"
  ]
}
